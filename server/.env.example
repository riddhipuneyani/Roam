DATABASE_URL="postgresql://roam:roam@localhost:5432/roam?schema=public"
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# OpenAI — server-side only, never exposed to the client.
# Leave OPENAI_API_KEY empty in dev to use the built-in sample itinerary
# (clearly logged on the server) so the full flow works without a key.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
