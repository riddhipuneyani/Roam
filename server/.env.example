DATABASE_URL="postgresql://roam:roam@localhost:5432/roam?schema=public"
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# Gemini (via Google's OpenAI-compatible endpoint) — server-side only,
# never exposed to the client. Leave GEMINI_API_KEY empty in dev to use
# the built-in sample itinerary (clearly logged on the server).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
