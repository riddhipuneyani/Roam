# Supabase Postgres. DATABASE_URL is the connection-pooling string used by
# the app at runtime (keep ?pgbouncer=true); DIRECT_URL is the direct
# connection Prisma uses for migrations. Both are on the Supabase dashboard
# under Settings -> Database.
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Supabase Storage for exported PDFs — the service role key is server-side
# only and must NEVER reach the frontend. The private bucket is created
# automatically on first export.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_PDF_BUCKET="trip-pdfs"

JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# Generation providers — all server-side only, never exposed to the client.
# Leave every key empty in dev to use the built-in sample itinerary
# (clearly logged on the server).
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Providers are tried in order; on a quota/rate-limit error, timeout, or
# outage the next entry serves the request. Entries whose provider has no
# API key are skipped. This is the default chain — uncomment to customize:
# GENERATION_CHAIN="gemini:gemini-2.5-flash,gemini:gemini-2.5-flash-lite,groq:llama-3.3-70b-versatile"

# Overrides the primary Gemini model when GENERATION_CHAIN is not set.
GEMINI_MODEL="gemini-2.5-flash"

# Per-request timeout before falling through to the next provider (ms).
# GENERATION_TIMEOUT_MS=120000
