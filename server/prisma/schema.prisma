generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries go through Supabase's connection pooler; migrations
  // need the direct connection (Prisma's standard pooler pattern).
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  trips        Trip[]
}

model Trip {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  destination String
  status      String        @default("draft")
  preferences Json
  itinerary   Json?
  /// Set when sharing is enabled; clearing it invalidates the public link.
  shareToken  String?       @unique
  /// Friendly failure reason when an async generation job ends in "failed".
  generationError String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  expenses    TripExpense[]

  @@index([userId])
}

enum ExpenseCategory {
  accommodation
  food
  activity
  transport
  shopping
  other
}

/// Nominatim results keyed by normalized query string, misses included,
/// so repeated generations never re-geocode the same place.
model GeoCache {
  id        String   @id @default(cuid())
  query     String   @unique
  lat       Float?
  lon       Float?
  createdAt DateTime @default(now())
}

model TripExpense {
  id          String          @id @default(cuid())
  tripId      String
  trip        Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  label       String
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @db.Char(3)
  date        DateTime
  notes       String?
  /// Who logged it — the owner's name via the dashboard, or the name a
  /// link visitor provides on the shared ledger.
  addedByName String
  createdAt   DateTime        @default(now())

  @@index([tripId])
}
